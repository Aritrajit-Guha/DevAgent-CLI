# Preferred simple setup: Gemini
GEMINI_API_KEY=

# Optional alternative Gemini credential name
GOOGLE_API_KEY=

# Optional second provider
GROQ_API_KEY=

# Optional third provider
XAI_API_KEY=

# Optional Gemini model overrides
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_DEEP=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional xAI model overrides
XAI_MODEL_FAST=grok-3-mini
XAI_MODEL=grok-3-mini
XAI_MODEL_DEEP=grok-3-mini
